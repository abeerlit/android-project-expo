{
  "name": "voxo-connect-android-expo",
  "version": "2.0.45",
  "private": true,
  "main": "index.js",
  "scripts": {
    "postinstall": "patch-package && node scripts/apply-callkeep-patch.cjs 2>/dev/null || true && node scripts/sync-ui-branding.js",
    "ui-branding:sync": "node scripts/sync-ui-branding.js",
    "vendor:sync-bare": "node scripts/vendor-sync-from-bare.js",
    "env:sync-ios": "node scripts/sync-env-from-ios-expo.js",
    "kill-metro": "lsof -ti :8082 | xargs kill -9 2>/dev/null; echo 'Metro port 8082 cleared'",
    "start": "npm run kill-metro && expo start --dev-client --port 8082",
    "start:device": "npm run kill-metro && expo start --dev-client --host lan --port 8082",
    "start:device:fresh": "npm run kill-metro && expo start --dev-client --host lan --port 8082 --clear",
    "android:reverse": "adb reverse tcp:8082 tcp:8082 && adb reverse tcp:8081 tcp:8082 && adb reverse --list",
    "android:open": "bash scripts/android-device-metro.sh",
    "android": "node scripts/refresh-android-autolinking.js && expo run:android",
    "android:setup": "node scripts/android-setup.js",
    "android:setup:clean": "node scripts/android-setup.js --prebuild-clean",
    "android:setup:verify": "node scripts/android-setup.js --verify",
    "prebuild": "expo prebuild --platform android",
    "prebuild:clean": "node scripts/android-setup.js --prebuild-clean",
    "lint": "eslint . --max-warnings 0",
    "check:types": "tsc -p tsconfig.json",
    "check:types:shell": "tsc -p tsconfig.shell.json",
    "check:types:ci": "tsc -p tsconfig.ci.json",
    "editor:build": "vite --config ./src/features/chat/editor/vite.config.ts build && node ./node_modules/@10play/tentap-editor/scripts/buildEditor.js ./src/features/chat/editor/build/index.html",
    "eas:development": "eas build --profile development --platform android",
    "eas:preview": "eas build --profile preview --platform android",
    "eas:production": "eas build --profile production --platform android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@10play/tentap-editor": "^0.7.2",
    "@alextbogdanov/react-native-emoji-selector": "^0.2.1",
    "@backpackapp-io/react-native-toast": "^0.11.0",
