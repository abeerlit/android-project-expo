API_URL=https://api.voxo.co
# Copy from ios-project-expo/.env (web OAuth client id + Azure app id)
GOOGLE_CLIENT_ID=
AZURE_CLIENT_ID=
SEND_BIRD_APP_ID=
SEND_BIRD_APP_TOKEN=
GIPHY_ANDROID_KEY=
SENTRY_DSN=

ENABLE_GOOGLE_SSO=true
ENABLE_MICROSOFT_SSO=true

EXPO_PUBLIC_MINIMAL_BOOT=0
EXPO_PUBLIC_CLEAR_PERSIST=0

# Phase gates — start at 0 for shell-only; use 1 for chat/calling/FCM dev client
EXPO_PUBLIC_NATIVE_TELEPHONY=0
EXPO_PUBLIC_NATIVE_NOTIFICATIONS=0
EXPO_PUBLIC_CHAT_NATIVE=0
# 1 = Daily.co meetings + screen share (requires native rebuild: npm run android:setup:clean)
EXPO_PUBLIC_MEETINGS_NATIVE=1
EXPO_PUBLIC_NATIVE_FULL=0

ANDROID_PACKAGE=co.voxo.android
DISPLAY_NAME=VOXO Connect
GOOGLE_SERVICES_JSON=./native-resources/google-services.json

# Play upload keystore (optional — defaults copy from ../android-project or native-resources/)
# VOXO_ANDROID_KEYSTORE=./native-resources/voxo.keystore
# MYAPP_UPLOAD_STORE_PASSWORD=
# MYAPP_UPLOAD_KEY_PASSWORD=
